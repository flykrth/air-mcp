# =============================================================================
# AIR-MCP Global Environment Configuration Template
# =============================================================================

# -----------------------------------------------------------------------------
# 1. FastAPI Backend Settings
# -----------------------------------------------------------------------------
PROJECT_NAME="AIR-MCP Mission Orchestrator"
API_V1_STR="/api/v1"
PORT=8000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# 2. Database Layer (Supabase Credentials)
# -----------------------------------------------------------------------------
# If left blank, the backend will automatically run in zero-dependency 
# "offline fallback mode" using thread-safe in-memory repositories.
# For persistent production environments, provide your Supabase details below:
SUPABASE_URL=
SUPABASE_KEY=

# -----------------------------------------------------------------------------
# 3. Node.js MCP Server Configuration
# -----------------------------------------------------------------------------
# Node environment mode: 'development' or 'production'
NODE_ENV=development

# Path to the MCP server workspace (used by FastAPI backend to spawn subprocess)
MCP_SERVER_DIR=./mcp-server

# Standalone MCP Transport configuration (used when running standalone container)
# Options: 'stdio' | 'http' | 'dual' (defaults to dual in production)
MCP_TRANSPORT_TYPE=dual
MCP_PORT=3000
MCP_HOST=0.0.0.0

# URL of the FastAPI backend, used by the MCP server to sync digital twin states
BACKEND_API_URL=https://air-mcp-production.up.railway.app

# -----------------------------------------------------------------------------
# 4. Next.js Frontend Configuration
# -----------------------------------------------------------------------------
# Build-time/Runtime environment variable targeting the FastAPI API Gateway
NEXT_PUBLIC_API_URL=https://air-mcp-production.up.railway.app/api/v1
